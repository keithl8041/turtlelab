# Server
HOST=0.0.0.0
PORT=3000

# OpenAI-compatible AI endpoint
# Set AI_API_KEY to enable AI-generated turtle drawings.
# AI_BASE_URL defaults to the OpenAI API; point it at any compatible endpoint
# (e.g. Azure OpenAI, Ollama, LM Studio, local llama.cpp server, etc.)
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4
AI_TIMEOUT_MS=30000

# Community gallery storage and admin
# Provide a full Azure Table SAS URL to store gallery entries.
# Example: https://<account>.table.core.windows.net/CommunityGallery?<sas-token>
COMMUNITY_GALLERY_TABLE_SAS_URL=
COMMUNITY_GALLERY_TABLE_PARTITION=gallery
ADMIN_PORTAL_PASSWORD=change-me
ADMIN_NOTIFICATION_WEBHOOK_URL=
