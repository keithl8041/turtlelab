# Server
HOST=0.0.0.0
PORT=3000

# OpenAI-compatible AI endpoint
# Set AI_API_KEY to enable AI-generated turtle drawings.
# AI_BASE_URL defaults to the OpenAI API; point it at any compatible endpoint
# (e.g. Azure OpenAI, Ollama, LM Studio, local llama.cpp server, etc.)
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=15000
